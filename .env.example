# Binance API (출금 권한 X, 거래 권한만)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Telegram 알림
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# 거래 설정
SYMBOL=BTCUSDT
LEVERAGE=3               # 최대 5 (절대 초과 금지)
SEED_USDT=100            # 운용 시드 (USDT)
MAX_POSITION_PCT=0.20    # 한 진입당 시드의 최대 비율 (20%)
DAILY_LOSS_LIMIT_PCT=0.30  # 일일 손실 한도 30% → Kill Switch

# 모드
DRY_RUN=true             # true = 페이퍼 트레이딩, false = 실거래
